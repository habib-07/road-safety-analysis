library(dplyr)
library(ggplot2)
# Définir le chemin du fichier
file_path <- "C:/Users/habib/Downloads/bat-ter.csv"
# Charger les données
df <- read.csv(file_path, stringsAsFactors = FALSE)
View(df)
cat("Nombre total d'enregistrements:", nrow(df), "\n")
# Comptage des valeurs non manquantes pour certaines colonnes spécifiques
commune_count <- sum(!is.na(df$Commune))
siren_epci_count <- sum(!is.na(df$siren_epci))
dep_com_count <- sum(!is.na(df$dep_com))
nombre_surface_count <- sum(!is.na(df$nombre) & !is.na(df$surface))
cat("Commune: seulement", commune_count, "valeurs renseignées.\n")
cat("siren_epci:", siren_epci_count, "valeurs renseignées.\n")
cat("dep_com:", dep_com_count, "valeurs renseignées.\n")
cat("nombre et surface:", nombre_surface_count, "valeurs renseignées.\n")
# Vérifier si idcom et dep_com sont bien numériques
cat("\nTypes des variables idcom et dep_com:\n")
str(df$idcom)
str(df$dep_com)
# Convertir les variables numériques en s'assurant qu'elles ne contiennent pas de caractères
df$nombre <- as.numeric(gsub(",", "", df$nombre)) # Supprimer les virgules éventuelles
df$surface <- as.numeric(gsub(",", "", df$surface))
# Vérifier les types après conversion
str(df)
# Statistiques descriptives des variables numériques
numeric_stats <- df %>% select(where(is.numeric)) %>% summary()
print(numeric_stats)
# Variance des variables numériques
variances <- df %>% select(where(is.numeric)) %>% summarise_all(var, na.rm = TRUE)
print(variances)
# Distribution des assujettis
assujetti_dist <- df %>% group_by(assujetti) %>% summarise(count = n())
assujetti_dist$percentage <- round((assujetti_dist$count / sum(assujetti_dist$count)) * 100, 2)
print(assujetti_dist)
# Charger les bibliothèques nécessaires
library(dplyr)
library(ggplot2)
# Définir le chemin du fichier
file_path <- "C:/Users/habib/Downloads/bat-ter.csv"
# Charger les données
df <- read.csv(file_path, stringsAsFactors = FALSE)
# ----------------------------
# 1. INFORMATIONS GÉNÉRALES
# ----------------------------
cat("Nombre total d'enregistrements:", nrow(df), "\n")
# Comptage des valeurs non manquantes pour certaines colonnes spécifiques
commune_count <- sum(!is.na(df$Commune))
siren_epci_count <- sum(!is.na(df$siren_epci))
dep_com_count <- sum(!is.na(df$dep_com))
nombre_surface_count <- sum(!is.na(df$nombre) & !is.na(df$surface))
cat("Commune: seulement", commune_count, "valeurs renseignées.\n")
cat("siren_epci:", siren_epci_count, "valeurs renseignées.\n")
cat("dep_com:", dep_com_count, "valeurs renseignées.\n")
cat("nombre et surface:", nombre_surface_count, "valeurs renseignées.\n")
# ----------------------------
# 2. STATISTIQUES SUR LES VARIABLES NUMÉRIQUES
# ----------------------------
# Vérifier si idcom et dep_com sont bien numériques
cat("\nTypes des variables idcom et dep_com:\n")
str(df$idcom)
str(df$dep_com)
# Convertir les variables numériques en s'assurant qu'elles ne contiennent pas de caractères
df$nombre <- as.numeric(gsub(",", "", df$nombre)) # Supprimer les virgules éventuelles
df$surface <- as.numeric(gsub(",", "", df$surface))
# Vérifier les types après conversion
str(df)
# Statistiques descriptives des variables numériques
numeric_stats <- df %>% select(where(is.numeric)) %>% summary()
print(numeric_stats)
# Variance des variables numériques
variances <- df %>% select(where(is.numeric)) %>% summarise_all(var, na.rm = TRUE)
print(variances)
# ----------------------------
# 3. DISTRIBUTION DES VARIABLES CATÉGORIQUES
# ----------------------------
# Distribution des assujettis
assujetti_dist <- df %>% group_by(assujetti) %>% summarise(count = n())
assujetti_dist$percentage <- round((assujetti_dist$count / sum(assujetti_dist$count)) * 100, 2)
print(assujetti_dist)
# Distribution de l'âge des bâtiments
age_dist <- df %>% group_by(age) %>% summarise(count = n()) %>% arrange(desc(count))
age_dist$percentage <- round((age_dist$count / sum(age_dist$count)) * 100, 2)
print(age_dist)
# Distribution des catégories de bâtiments
categorie_dist <- df %>% group_by(categorie) %>% summarise(count = n()) %>% arrange(desc(count))
categorie_dist$percentage <- round((categorie_dist$count / sum(categorie_dist$count)) * 100, 2)
print(categorie_dist)
# ----------------------------
# 4. VISUALISATION DES DISTRIBUTIONS
# ----------------------------
# Diagramme en barres pour les assujettis
ggplot(assujetti_dist, aes(x = assujetti, y = count, fill = assujetti)) +
geom_bar(stat = "identity") +
labs(title = "Répartition des assujettis", x = "Assujetti", y = "Nombre d'observations") +
theme_minimal()
# Histogramme corrigé de la variable "nombre"
ggplot(df %>% filter(!is.na(nombre)), aes(x = nombre)) +
geom_histogram(binwidth = 10, fill = "blue", alpha = 0.7) +
labs(title = "Distribution de la variable 'nombre'", x = "Nombre", y = "Fréquence") +
theme_minimal()
# Histogramme corrigé de la variable "surface"
ggplot(df %>% filter(!is.na(surface)), aes(x = surface)) +
geom_histogram(binwidth = 500, fill = "red", alpha = 0.7) +
labs(title = "Distribution de la variable 'surface'", x = "Surface (m²)", y = "Fréquence") +
theme_minimal()
# Diagramme en barres pour la variable "age"
ggplot(age_dist, aes(x = reorder(age, -count), y = count, fill = age)) +
geom_bar(stat = "identity") +
labs(title = "Répartition des âges des bâtiments", x = "Âge", y = "Nombre d'observations") +
theme_minimal() +
coord_flip()
# Diagramme en barres pour la variable "categorie"
ggplot(categorie_dist, aes(x = reorder(categorie, -count), y = count, fill = categorie)) +
geom_bar(stat = "identity") +
labs(title = "Répartition des catégories de bâtiments", x = "Catégorie", y = "Nombre d'observations") +
theme_minimal() +
coord_flip()
# Assurer que les variables numériques sont bien traitées comme telles
df$nombre <- as.numeric(df$nombre)
df$surface <- as.numeric(df$surface)
# ----------------------------
# 1. ANALYSE À L'ÉCHELLE DU DÉPARTEMENT (DEP)
# ----------------------------
df_dep <- df %>% filter(maille == "DEP", !is.na(dep_com), assujetti == "O")
# Nombre total de bâtiments assujettis
nb_batiments_dep <- sum(df_dep$nombre, na.rm = TRUE)
# Surface totale des bâtiments assujettis (m²)
surface_totale_dep <- sum(df_dep$surface, na.rm = TRUE)
# Répartition des bâtiments assujettis par catégorie
repartition_categories_dep <- df_dep %>%
group_by(categorie) %>%
summarise(nombre_total = sum(nombre, na.rm = TRUE)) %>%
arrange(desc(nombre_total))
print(repartition_categories_dep)
# ----------------------------
# 2. ANALYSE À L'ÉCHELLE DES COMMUNES DU VAL-DE-MARNE (94)
# ----------------------------
df_communes_94 <- df %>%
filter(maille == "COMMUNE", grepl("^94", as.character(idcom)), assujetti == "O")
# Top 10 des communes avec le plus de bâtiments assujettis
top_10_communes_batiments <- df_communes_94 %>%
group_by(Commune) %>%
summarise(nombre_total = sum(nombre, na.rm = TRUE)) %>%
arrange(desc(nombre_total)) %>%
head(10)
print(top_10_communes_batiments)
# Top 10 des communes avec la plus grande surface assujettie
top_10_communes_surface <- df_communes_94 %>%
group_by(Commune) %>%
summarise(surface_totale = sum(surface, na.rm = TRUE)) %>%
arrange(desc(surface_totale)) %>%
head(10)
print(top_10_communes_surface)
# ----------------------------
# 3. ANALYSE À L'ÉCHELLE DES EPT DU VAL-DE-MARNE (94)
# ----------------------------
df_ept_94 <- df %>%
filter(maille == "EPCI", siren_epci %in% c("T10", "T11", "T12"), assujetti == "O")
# Nombre total de bâtiments assujettis
nb_batiments_ept <- sum(df_ept_94$nombre, na.rm = TRUE)
# Nombre de bâtiments assujettis par catégorie
nb_batiments_par_categorie_ept <- df_ept_94 %>%
group_by(categorie) %>%
summarise(nombre_total = sum(nombre, na.rm = TRUE)) %>%
arrange(desc(nombre_total))
print(nb_batiments_par_categorie_ept)
# Surface totale des bâtiments assujettis par catégorie
surface_totale_par_categorie_ept <- df_ept_94 %>%
group_by(categorie) %>%
summarise(surface_totale = sum(surface, na.rm = TRUE)) %>%
arrange(desc(surface_totale))
print(surface_totale_par_categorie_ept)
# ----------------------------
# 4. VISUALISATIONS (Avec valeurs sur les graphiques)
# ----------------------------
# Graphique des catégories de bâtiments au niveau du département
ggplot(repartition_categories_dep, aes(x = reorder(categorie, -nombre_total), y = nombre_total, fill = categorie)) +
geom_bar(stat = "identity") +
geom_text(aes(label = nombre_total), hjust = -0.2) +  # Ajout des valeurs sur les barres
coord_flip() +
labs(title = "Répartition des bâtiments assujettis par catégorie (Département)",
x = "Catégorie", y = "Nombre de bâtiments") +
theme_minimal()
# Graphique des 10 communes ayant le plus de bâtiments assujettis (avec valeurs)
ggplot(top_10_communes_batiments, aes(x = reorder(Commune, -nombre_total), y = nombre_total, fill = Commune)) +
geom_bar(stat = "identity") +
geom_text(aes(label = nombre_total), hjust = -0.2) +  # Ajout des valeurs sur les barres
coord_flip() +
labs(title = "Top 10 des communes avec le plus de bâtiments assujettis (Val-de-Marne)",
x = "Commune", y = "Nombre de bâtiments") +
theme_minimal()
# Graphique des 10 communes avec la plus grande surface assujettie (avec valeurs)
ggplot(top_10_communes_surface, aes(x = reorder(Commune, -surface_totale), y = surface_totale, fill = Commune)) +
geom_bar(stat = "identity") +
geom_text(aes(label = surface_totale), hjust = -0.2) +  # Ajout des valeurs sur les barres
coord_flip() +
labs(title = "Top 10 des communes avec la plus grande surface assujettie (Val-de-Marne)",
x = "Commune", y = "Surface totale (m²)") +
theme_minimal()
# Graphique des bâtiments assujettis par catégorie au niveau des EPT du Val-de-Marne
ggplot(nb_batiments_par_categorie_ept, aes(x = reorder(categorie, -nombre_total), y = nombre_total, fill = categorie)) +
geom_bar(stat = "identity") +
geom_text(aes(label = nombre_total), hjust = -0.2) +  # Ajout des valeurs sur les barres
coord_flip() +
labs(title = "Nombre de bâtiments assujettis par catégorie (EPT - Val-de-Marne)",
x = "Catégorie", y = "Nombre de bâtiments") +
theme_minimal()
# Graphique de la surface totale des bâtiments assujettis par catégorie au niveau des EPT
ggplot(surface_totale_par_categorie_ept, aes(x = reorder(categorie, -surface_totale), y = surface_totale, fill = categorie)) +
geom_bar(stat = "identity") +
geom_text(aes(label = surface_totale), hjust = -0.2) +  # Ajout des valeurs sur les barres
coord_flip() +
labs(title = "Surface totale des bâtiments assujettis par catégorie (EPT - Val-de-Marne)",
x = "Catégorie", y = "Surface totale (m²)") +
theme_minimal()
# ----------------------------
# 5. AFFICHAGE DES RÉSULTATS GLOBAUX
# ----------------------------
cat("\n### Résumé des résultats ###\n")
cat("Nombre total de bâtiments assujettis (Département) :", nb_batiments_dep, "\n")
cat("Surface totale des bâtiments assujettis (Département) :", surface_totale_dep, "m²\n")
cat("Nombre total de bâtiments assujettis (EPT - Val-de-Marne) :", nb_batiments_ept, "\n")
