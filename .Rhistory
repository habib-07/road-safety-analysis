# 5. AFFICHAGE DES RÉSULTATS GLOBAUX
# ----------------------------
cat("\n### Résumé des résultats ###\n")
cat("Nombre total de bâtiments assujettis (Département) :", nb_batiments_dep, "\n")
cat("Surface totale des bâtiments assujettis (Département) :", surface_totale_dep, "m²\n")
