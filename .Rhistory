library(tidyverse)
library(lubridate)
chemin_raw  <- "C:/Users/habib/Desktop/BAAC"
chemin_proc <- file.path(chemin_raw, "processed")
dir.create(chemin_proc, showWarnings = FALSE)
mois_fr <- c("janv","fevr","mars","avr","mai","juin",
"juil","aout","sept","oct","nov","dec")
caract <- read_delim(file.path(chemin_raw, "caract-2024.csv"), delim=";",
locale=locale(encoding="UTF-8", decimal_mark=","), show_col_types=FALSE) |>
mutate(annee=2024L)
lieux     <- read_delim(file.path(chemin_raw, "lieux-2024.csv"),     delim=";", locale=locale(encoding="UTF-8"), show_col_types=FALSE)
usagers   <- read_delim(file.path(chemin_raw, "usagers-2024.csv"),   delim=";", locale=locale(encoding="UTF-8"), show_col_types=FALSE)
vehicules <- read_delim(file.path(chemin_raw, "vehicules-2024.csv"), delim=";", locale=locale(encoding="UTF-8"), show_col_types=FALSE)
message("Import OK : ", nrow(caract), " accidents")
caract_clean <- caract |> mutate(
lat      = as.numeric(str_replace(lat,  ",", ".")),
long     = as.numeric(str_replace(long, ",", ".")),
date     = dmy(paste(jour, mois, an, sep="/")),
heure    = as.integer(str_extract(hrmn, "^\\d+")),
mois_lab = mois_fr[month(date)],
lum_lib  = case_when(lum==1~"Plein jour",lum==2~"Crepuscule",lum==3~"Nuit sans eclairage",lum==4~"Nuit eclairage eteint",lum==5~"Nuit eclairage allume",TRUE~"Inconnu"),
atm_lib  = case_when(atm==-1~"Inconnu",atm==1~"Normale",atm==2~"Pluie legere",atm==3~"Pluie forte",atm==4~"Neige",atm==5~"Brouillard",atm==6~"Vent fort",atm==7~"Eblouissant",atm==8~"Couvert",TRUE~"Inconnu"),
col_lib  = case_when(col==-1~"Inconnu",col==1~"Frontale",col==2~"Arriere",col==3~"Cote",col==4~"En chaine",col==5~"Multiple",col==6~"Autre",col==7~"Sans collision",TRUE~"Inconnu")
)
lieux_clean <- lieux |> mutate(
catr_lib = case_when(catr==1~"Autoroute",catr==2~"Route nationale",catr==3~"Route departementale",catr==4~"Voie communale",catr==5~"Hors reseau",catr==6~"Parking",catr==9~"Autre",TRUE~"Inconnu"),
surf_lib = case_when(surf==-1~"Inconnu",surf==1~"Normale",surf==2~"Mouillee",surf==3~"Flaques",surf==4~"Inondee",surf==5~"Enneigee",surf==6~"Boue",surf==7~"Verglacee",surf==8~"Corps gras",TRUE~"Autre"),
prof_lib = case_when(prof==-1~"Inconnu",prof==1~"Plat",prof==2~"Pente",prof==3~"Sommet",prof==4~"Bas de cote",TRUE~"Inconnu")
)
usagers_clean <- usagers |> mutate(
grav_lib    = case_when(grav==1~"Indemne",grav==2~"Tue",grav==3~"Blesse hospitalise",grav==4~"Blesse leger",TRUE~"Inconnu"),
catu_lib    = case_when(catu==1~"Conducteur",catu==2~"Passager",catu==3~"Pieton",TRUE~"Autre"),
sexe_lib    = case_when(sexe==1~"Masculin",sexe==2~"Feminin",TRUE~"Inconnu"),
an_nais_num = as.integer(str_trim(as.character(an_nais))),
age         = if_else(!is.na(an_nais_num) & an_nais_num>1900, 2024L-an_nais_num, NA_integer_),
tranche_age = case_when(age<18~"Moins de 18 ans",age%in%18:24~"18-24 ans",age%in%25:34~"25-34 ans",age%in%35:44~"35-44 ans",age%in%45:64~"45-64 ans",age>=65~"65 ans et plus",TRUE~"Inconnu")
)
gravite_acc <- usagers_clean |>
group_by(Num_Acc) |>
summarise(nb_tues=sum(grav==2,na.rm=TRUE), nb_blesses_hosp=sum(grav==3,na.rm=TRUE),
nb_blesses_legers=sum(grav==4,na.rm=TRUE), nb_indemnes=sum(grav==1,na.rm=TRUE),
nb_usagers=n(), .groups="drop") |>
mutate(gravite_max=case_when(nb_tues>0~"Mortel",nb_blesses_hosp>0~"Grave",nb_blesses_legers>0~"Leger",TRUE~"Materiel"))
accidents <- caract_clean |>
left_join(lieux_clean, by="Num_Acc") |>
left_join(gravite_acc, by="Num_Acc")
message("Table finale : ", nrow(accidents), " lignes")
message("Mortels : ", sum(accidents$gravite_max=="Mortel", na.rm=TRUE))
saveRDS(accidents,     file.path(chemin_proc, "accidents_clean.rds"))
saveRDS(usagers_clean, file.path(chemin_proc, "usagers_clean.rds"))
message("Donnees sauvegardees !")
